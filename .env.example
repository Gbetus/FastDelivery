# Copiar a .env:  cp .env.example .env
# Docker Compose lee solo el archivo .env en esta carpeta.

# --- Imágenes ---
MARIADB_IMAGE=mariadb:11
MONGO_IMAGE=mongo:7
# REDIS_IMAGE=redis:7-alpine

# --- Puertos (host) ---
MARIADB_PUBLISHED_PORT=3306
MONGO_PUBLISHED_PORT=27017
# REDIS_PUBLISHED_PORT=6379

# --- Nombres de contenedor ---
MARIADB_CONTAINER_NAME=fastdelivery-mariadb
MONGO_CONTAINER_NAME=fastdelivery-mongo
# REDIS_CONTAINER_NAME=fastdelivery-redis

# --- MariaDB — deben coincidir con DB_* en api/.env ---
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=fastdelivery
MYSQL_USER=fastdelivery
MYSQL_PASSWORD=fastdelivery

# --- MongoDB root ---
MONGO_INITDB_ROOT_USERNAME=fastdelivery
MONGO_INITDB_ROOT_PASSWORD=fastdelivery
