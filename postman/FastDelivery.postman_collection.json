          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerNombre\": \"{{orderCustomerNombre}}\",\n  \"customerTelefono\": \"{{orderCustomerTelefono}}\",\n  \"customerDireccionEntrega\": \"{{orderCustomerDireccion}}\",\n  \"notasPedido\": \"{{orderNotasPedido}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.environment.set('orderId', String(json.id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Cambiar estado a EN_CAMINO",
