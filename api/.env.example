NODE_ENV=development
PORT=3000

# === SQL: igual que MYSQL_* y MYSQL_DATABASE del .env en la raíz del repo ===
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fastdelivery
DB_PASSWORD=fastdelivery
DB_NAME=fastdelivery

# === Mongo: usuario/clave/puerto = MONGO_INITDB_* y MONGO_PUBLISHED_PORT del .env raíz ===
MONGODB_URI=mongodb://fastdelivery:fastdelivery@127.0.0.1:27017/fastdelivery_tracking?authSource=admin

# Redis no esta en uso actualmente
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

JWT_SECRET=cambiar_por_un_secreto_largo_en_produccion
JWT_EXPIRES_IN=15m

SEED_ENABLED=true
SEED_USER_EMAIL=repartidor@fastdelivery.local
SEED_USER_PASSWORD=RepartidorPassword
SEED_USER_NAME=Repartidor Demo

# Admin para endpoints protegidos de gestion
ADMIN_USER_EMAIL=admin@fastdelivery.local
ADMIN_USER_PASSWORD=AdminPassword
ADMIN_USER_NAME=Admin FastDelivery
